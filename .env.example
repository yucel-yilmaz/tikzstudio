# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tikzlab"

# better-auth: random 32+ byte secret
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="replace-me-with-a-strong-random-string"

# Public URL the app is served from (used by better-auth for callbacks/cookies)
BETTER_AUTH_URL="http://localhost:3000"

# Sandboxed compile limits (Docker container resource caps)
COMPILE_TIMEOUT_SECONDS=15
COMPILE_MEMORY_LIMIT_MB=256
COMPILE_CPU_LIMIT=0.5

# Source/output safety limits
MAX_SOURCE_SIZE_KB=512
MAX_OUTPUT_SIZE_MB=10

# Docker image tag built by `npm run compiler:build`
DOCKER_COMPILER_IMAGE="tikzlab-compiler:latest"

# Local directory where compile artifacts (PDF/SVG) are persisted.
# Excluded from version control via .gitignore (.data/).
COMPILE_STORAGE_DIR=".data/compile-artifacts"
