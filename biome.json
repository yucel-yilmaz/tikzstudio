{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.next",
			"!**/.next-build",
			"!**/.data",
			"!**/generated",
			"!**/dist",
			"!**/build",
			"!**/*.tsbuildinfo",
			"!**/app/globals.css"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["components/ui/**"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"useFocusableInteractive": "off",
						"useAriaPropsForRole": "off",
						"useKeyWithClickEvents": "off",
						"noLabelWithoutControl": "off"
					},
					"suspicious": {
						"noArrayIndexKey": "off",
						"noDocumentCookie": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts", "**/*.test.tsx", "tests/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["features/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noLabelWithoutControl": "off"
					},
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": ["lib/prisma.ts", "prisma/seed.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noRedeclare": "off"
					},
					"complexity": {
						"noUselessStringRaw": "off"
					}
				}
			}
		}
	]
}
